{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Developer Machine Cleaner",
  "version": "0.5.0",
  "identifier": "com.devcleanup.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Developer Machine Cleaner",
        "width": 1100,
        "height": 720,
        "minWidth": 820,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Maks417/DevMachineCleaner/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYxRDU2REJDNkIyNzA4NUIKUldSYkNDZHJ2RzNWWVJrWHg2TklDS3NwS0ZmMmhUU2hRaW5YYkVqcEZHVko3eTczOWxmaFNwODAK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg", "appimage", "deb", "nsis", "msi"],
    "category": "DeveloperTool",
    "shortDescription": "Reclaim disk space by cleaning dev build artifacts and AI caches.",
    "longDescription": "Cross-platform desktop app that detects developer project artifacts (node_modules, target, .venv, build, ...) and known AI/LLM caches and moves the selected ones to the OS Recycle Bin / Trash so they can be recovered.",
    "copyright": "Copyright (c) 2026 Max Davydov",
    "publisher": "Max Davydov",
    "homepage": "https://github.com/Maks417/DevMachineCleaner",
    "license": "MIT",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
